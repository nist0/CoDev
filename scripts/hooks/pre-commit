#!/bin/sh
# CoDev pre-commit hook — runs routing and markdown lint validation before every commit.
#
# Installation:
#   cp scripts/hooks/pre-commit .git/hooks/pre-commit
#   chmod +x .git/hooks/pre-commit
#
# Or use the install script:
#   python scripts/install-hooks.py
#
# To skip (emergency only):
#   git commit --no-verify

set -e

PYTHON="${PYTHON:-python}"
REPO_ROOT="$(git rev-parse --show-toplevel)"
SCRIPTS_DIR="$REPO_ROOT/scripts"

echo "CoDev pre-commit validation..."

CHANGED=$(git diff --cached --name-only)
ROUTING_CHANGED=$(echo "$CHANGED" | grep -E "^(routing/|\.github/(agents|prompts|skills|instructions))" || true)
MD_CHANGED=$(echo "$CHANGED" | grep -E "\.md$" | grep -v "^\.venv/" | grep -v "/\.venv/" | grep -v "/node_modules/" || true)

if [ -z "$ROUTING_CHANGED" ] && [ -z "$MD_CHANGED" ]; then
  echo "  -- No routing/.github or Markdown changes -- skipping validation."
  exit 0
fi

FAILED=0

run_validator() {
  SCRIPT="$1"
  LABEL="$2"
  if [ -f "$SCRIPTS_DIR/$SCRIPT" ]; then
    if "$PYTHON" "$SCRIPTS_DIR/$SCRIPT"; then
      echo "  OK $LABEL"
    else
      echo "  FAIL $LABEL"
      FAILED=1
    fi
  else
    echo "  -- $LABEL -- script not found, skipping"
  fi
}

# --- Routing validators (only when routing/.github files changed) ---
if [ -n "$ROUTING_CHANGED" ]; then
  echo ""
  echo "  Routing/.github files changed:"
  echo "$ROUTING_CHANGED" | sed 's/^/    /'
  echo ""
  run_validator "validate-route-smoke.py"            "Route smoke tests"
  run_validator "validate-autofix.py"                "Auto-fix detection (detect only)"
  run_validator "validate-customization-registry.py" "Customization registry"
  run_validator "validate-readme-registry.py"        "README registry"
  run_validator "validate-routing-coverage.py"       "Routing coverage"
fi

# --- Markdown lint (only when .md files changed) ---
if [ -n "$MD_CHANGED" ]; then
  echo ""
  echo "  Markdown files changed:"
  echo "$MD_CHANGED" | sed 's/^/    /'
  echo ""
  run_validator "validate-markdown-lint.py" "Markdown lint"
fi

echo ""
if [ "$FAILED" -eq 1 ]; then
  echo "FAIL Pre-commit validation failed. Fix the issues above."
  echo "     For routing fixes: python scripts/validate-autofix.py --fix"
  echo "     For markdown fixes: npx markdownlint-cli2 --fix \"**/*.md\" \"!.venv/**\""
  echo ""
  echo "     To bypass (emergency only): git commit --no-verify"
  exit 1
fi

echo "OK All validations passed."
exit 0
